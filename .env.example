# 🔧 Конфигурация API ключей и настроек

# ===== ОСНОВНЫЕ API КЛЮЧИ =====
# Genius API для скрапинга текстов песен
GENIUS_TOKEN=your_genius_token_here

# ===== AI АНАЛИЗ (выберите один или несколько) =====

# 1. Ollama (РЕКОМЕНДУЕТСЯ - бесплатно, локально)
# Убедитесь что Ollama запущен: ollama serve
# Модель будет загружена автоматически: llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# 2. DeepSeek API (дешевый fallback - $0.003/песня)
# Регистрация: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 3. Google Gemini (УСТАРЕЛО - только 50 запросов/день)
# GOOGLE_API_KEY=your_gemini_api_key_here

# 4. Google Gemma 3 27B (НОВЫЙ - мощный, но с лимитами)
# Регистрация: https://console.cloud.google.com
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_PROJECT_ID=your_google_project_id

# ===== НАСТРОЙКИ АНАЛИЗА =====
# Лимит песен для batch анализа
BATCH_ANALYSIS_LIMIT=100

# Задержка между запросами (секунды)
ANALYSIS_DELAY=2

# Лимит памяти для оптимизированного скрапера (МБ)
MEMORY_LIMIT_MB=2048

# ===== БАЗА ДАННЫХ =====
# Путь к основной базе данных
DATABASE_PATH=rap_lyrics.db

# Создавать ли резервные копии при merge
AUTO_BACKUP=true

# ===== ЛОГИРОВАНИЕ =====
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=scraping.log
