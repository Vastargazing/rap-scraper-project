{
  "project_name": "rap-scraper",
  "version": "2.0.0",
  "environment": "development",
  
  "database": {
    "path": "data/rap_lyrics.db",
    "timeout": 30.0,
    "pool_size": 5
  },
  
  "analysis": {
    "batch_size": 20,
    "max_workers": 4,
    "default_confidence_threshold": 0.7,
    "supported_analyzers": ["algorithmic_basic", "gemma", "ollama", "hybrid"]
  },
  
  "logging": {
    "level": "INFO",
    "file_path": "logs/rap_scraper.log"
  },
  
  "api": {
    "request_delay": 1.0,
    "max_requests_per_minute": 60
  },
  
  "analyzers": {
    "algorithmic_basic": {
      "min_word_length": 3,
      "sentiment_threshold": 0.1
    },
    
    "gemma": {
      "model_name": "gemma-2-27b-it",
      "temperature": 0.1,
      "max_tokens": 1500,
      "timeout": 30
    },
    
    "ollama": {
      "model_name": "llama3.2:3b",
      "base_url": "http://localhost:11434",
      "temperature": 0.1,
      "timeout": 60
    },
    
    "hybrid": {
      "primary_analyzer": "gemma",
      "secondary_analyzer": "algorithmic_basic",
      "fallback_analyzer": "ollama",
      "ai_weight": 0.7,
      "algorithmic_weight": 0.3,
      "min_confidence_threshold": 0.5,
      "use_fallback_threshold": 0.3
    }
  }
}
